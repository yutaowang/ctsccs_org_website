VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Server-side Auth migration only. Rotate this key after migration.
SUPABASE_SERVICE_ROLE_KEY=YOUR_ROTATED_SERVICE_ROLE_KEY

# Server-side import only. Never use this value in frontend code.
# Get it from Supabase: Connect > Session pooler or Direct connection.
SUPABASE_DB_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
# Recommended when the direct database host is IPv6-only.
SUPABASE_DB_POOLER_URL=postgresql://POOLER_USER:PASSWORD@POOLER_HOST:5432/postgres

# Vercel server-side password reset email. Do not prefix these with VITE_.
GOOGLE_SMTP_HOST=smtp.gmail.com
GOOGLE_SMTP_PORT=587
GOOGLE_SMTP_USER=school-account@example.org
GOOGLE_SMTP_APP_PASSWORD=YOUR_GOOGLE_APP_PASSWORD
MAIL_FROM_NAME=SCCS
MAIL_FROM_ADDRESS=school-account@example.org
SITE_URL=https://www.example.org
